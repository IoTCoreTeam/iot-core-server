# MongoDB connection
MONGODB_URI=mongodb://127.0.0.1:27017
DATABASE_NAME=sensor-data
SENSOR_COLLECTION_NAME=sensor_readings
SERVO_ACK_COLLECTION_NAME=servo_acks
CONTROL_ACK_COLLECTION_NAME=control_acks

# Server configuration
APP_HOST=0.0.0.0
APP_PORT=8017
MQTT_PORT=1883
AUTHOR=IoTCoreTeam
BUILD_MODE=dev

# Integrations
LARAVEL_API_URL=http://localhost:8000/api
CLIENT_URL=http://localhost:3000
CONTROL_MODULE_AVAILABLE_NODES_URL=http://localhost:8000/api/available-nodes
DEVICE_ACTIVITY_REQUEST_TIMEOUT_MS=5000

# Service-to-service auth (backend -> server)
# Use a strong 32-byte random token encoded as hex (64 chars), e.g. openssl rand -hex 32
SERVICE_TOKEN=

# JWT verification settings (legacy path; optional if only SERVICE_TOKEN is used)
JWT_PUBLIC_KEY_PATH=storage/oauth-public.key
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ALGORITHMS=RS256
JWT_ROLE_CLAIM=roles
JWT_SCOPE_CLAIM=scope
JWT_CLOCK_TOLERANCE_SEC=5
