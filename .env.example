# MongoDB connection (connect to `iot-core-sensor-data` and use the `sensor_readings` collection).
MONGODB_URI=mongodb://127.0.0.1:27017/iot-core-sensor-data
DATABASE_NAME=sensor_readings
SENSOR_COLLECTION_NAME=sensor_readings

# Server configuration
APP_HOST=0.0.0.0
APP_PORT=8017
MQTT_PORT=1883
AUTHOR=IoTCoreTeam
BUILD_MODE=dev

# Integrations (override URLs as required for your environment)
LARAVEL_API_URL=http://localhost:8000/api
CLIENT_URL=http://localhost:3000

# Token settings
ACCESS_TOKEN_SECRET_SIGNATURE=replace-with-strong-secret
ACCESS_TOKEN_LIFE=15m
REFRESH_TOKEN_SECRET_SIGNATURE=replace-with-strong-secret
REFRESH_TOKEN_LIFE=7d

# Optional override for the available nodes URL (defaults to http://127.0.0.1:8100/api/available-nodes)
CONTROL_MODULE_AVAILABLE_NODES_URL=
# Device activity HTTP timeout (ms)
DEVICE_ACTIVITY_REQUEST_TIMEOUT_MS=5000
